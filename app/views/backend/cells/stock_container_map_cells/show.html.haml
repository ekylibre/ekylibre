- bd_with_shape_ids = BuildingDivision.all.map{|b| (b.shape.present? ? b.id : nil)}.compact
- bd = BuildingDivision.where(id: bd_with_shape_ids)
- if @campaigns && bd.any?
  = visualization({ async_url: backend_visualizations_stock_container_map_cells_visualizations_path(@url_params) }, {}) do |v|
    - v.control :zoom
    - v.control :scale
    - v.control :fullscreen
    - v.control :layer_selector
    - v.center bd.first.shape.centroid
- else
  .placeholding-message= :no_building.tn  
