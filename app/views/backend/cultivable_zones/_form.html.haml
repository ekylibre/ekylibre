= field_set do
  = f.input :name
  = f.input :work_number
  = f.referenced_nomenclature :production_system
  = f.referenced_nomenclature :soil_nature
  = f.referenced_association :farmer
  = f.referenced_association :owner
  = f.input :description
  -# = f.input :uuid
  -# = f.shape :shape
  - optional_data = { optional_data_url: backend_map_editor_shapes_path(layers: [:cadastral_parcels]) }
  = f.geometry :shape, { show: {}, editor: { useFeatures: true, overlaySelector: { editionLayer: f.object.human_attribute_name(:shape) }, dynamic_series: backend_map_editor_shapes_path(layers: [:cultivable_zones]) }.merge(optional_data) }
  = f.custom_fields